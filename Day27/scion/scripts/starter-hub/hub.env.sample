# Scion Hub Environment Configuration
# Copy this file to .scratch/hub-<name>.env (e.g., hub-demo.env) and fill in
# your values. The deploy script (gce-start-hub.sh --full) uploads it to the
# instance. The file name must match your HUB_NAME (default: "demo").

# === Required ===
SCION_HUB_STORAGE_BUCKET=your-gcs-bucket-name
SESSION_SECRET=<generate-with: openssl rand -base64 32>

# === Hub & Registry ===
SCION_HUB_ENDPOINT=https://your-hub-domain.example.com
SCION_IMAGE_REGISTRY=your-registry.example.com/your-project/your-repo

# === OAuth — Web Clients ===
# See docs: https://scion-ai.dev/hub-admin/auth/
SCION_SERVER_OAUTH_WEB_GOOGLE_CLIENTID=your-google-web-client-id.apps.googleusercontent.com
SCION_SERVER_OAUTH_WEB_GOOGLE_CLIENTSECRET=your-google-web-client-secret
SCION_SERVER_OAUTH_WEB_GITHUB_CLIENTID=your-github-web-client-id
SCION_SERVER_OAUTH_WEB_GITHUB_CLIENTSECRET=your-github-web-client-secret

# === OAuth — CLI Clients ===
SCION_SERVER_OAUTH_CLI_GOOGLE_CLIENTID=your-google-cli-client-id.apps.googleusercontent.com
SCION_SERVER_OAUTH_CLI_GOOGLE_CLIENTSECRET=your-google-cli-client-secret
SCION_SERVER_OAUTH_CLI_GITHUB_CLIENTID=your-github-cli-client-id
SCION_SERVER_OAUTH_CLI_GITHUB_CLIENTSECRET=your-github-cli-client-secret

# === Domain Authorization (optional) ===
# Comma-separated list of allowed email domains. Empty = allow all.
# SCION_AUTHORIZED_DOMAINS=example.com,mycompany.org

# === Telemetry (OTEL) ===
# Hub-side telemetry configuration. Loaded by the systemd unit via EnvironmentFile.
SCION_CLOUD_LOGGING=true
SCION_GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
SCION_OTEL_ENDPOINT=cloudtrace.googleapis.com:443
SCION_OTEL_LOG_ENABLED=true

# === Optional ===
# SCION_LOG_LEVEL=debug
