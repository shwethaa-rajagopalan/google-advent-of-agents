# .gcloudignore
# Common exclusions for gcloud builds submit and other gcloud commands.

# Basic git exclusions
.git
.gitignore

# Node.js exclusions
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Astro specific exclusions
dist/
.astro/

# IDE and OS exclusions
.vscode/
.DS_Store

# Infrastructure files (usually not needed in the build context unless specific)
cloudbuild.yaml
.gcloudignore

# Local deployment scripts
deploy.sh