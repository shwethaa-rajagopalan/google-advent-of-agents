# Ignore local environment and secrets
.design/
.scion/
.gemini/
*key*
*secret*
*.env

# Ignore version control (can be large)
.git/

# Ignore IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore test artifacts and binaries
*.test
*.out
coverage.txt

# Ignore node_modules if present
node_modules/

# Ignore documentation not needed for build
*.md
!go.mod
!go.sum

# Ignore other common large directories
vendor/
tmp/
.cache/
