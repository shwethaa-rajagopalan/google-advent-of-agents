{
  "name": "@scion/web-frontend",
  "version": "0.1.0",
  "description": "Scion Web Frontend - Browser-based dashboard for managing agents and groves",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rm -rf node_modules dist public/assets public/shoelace",
    "postinstall": "npm run copy:shoelace-icons",
    "dev": "npm run copy:shoelace-icons && vite --mode development",
    "build": "npm run copy:shoelace-icons && vite build && npm run copy:client",
    "build:dev": "npm run copy:shoelace-icons && vite build --mode development && npm run copy:client",
    "copy:client": "mkdir -p public/assets && cp -r dist/client/assets/* public/assets/",
    "copy:shoelace-icons": "node scripts/copy-shoelace-icons.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.19.0",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lit": "^3.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "bootstrap-icons": "^1.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
