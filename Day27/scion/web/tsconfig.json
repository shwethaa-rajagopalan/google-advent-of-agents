{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "exactOptionalPropertyTypes": true
    },
    "include": [
        "src/client/**/*",
        "src/components/**/*",
        "src/shared/**/*",
        "src/styles/**/*",
        "src/vite-env.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "public"
    ]
}
